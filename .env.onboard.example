# ============================================================================
# StayBid Onboarding Panel — Environment Variables
# ============================================================================
# Copy any of these into Vercel → Settings → Environment Variables.
# All have sensible mock fallbacks; the system runs end-to-end without keys.

# ---- Supabase --------------------------------------------------------------
# Service-role key is preferred (bypasses RLS). Optional — falls back to the
# JWT anon key already hardcoded in lib/onboard/supabase-admin.ts.
SUPABASE_URL=https://uxxhbdqedazpmvbvaosh.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# ---- Auth ------------------------------------------------------------------
# JWT secret for onboarding tokens. Falls back to a dev constant if unset.
ONBOARD_JWT_SECRET=

# ---- Email (OTP delivery) --------------------------------------------------
# Set SENDGRID_API_KEY to enable real emails. Otherwise OTPs are logged
# to server console (good for dev / preview).
EMAIL_PROVIDER=sendgrid          # sendgrid | mock | (future: resend, ses)
SENDGRID_API_KEY=
EMAIL_FROM=StayBid <noreply@staybids.in>

# ---- SMS / WhatsApp (OTP delivery) -----------------------------------------
# Default uses Railway WhatsApp endpoint. To switch to Twilio, set provider
# + creds. Set to "mock" to log codes to console only.
SMS_PROVIDER=                    # railway-whatsapp | twilio | mock
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# ---- AI Hotel Search -------------------------------------------------------
# Add SerpAPI key for live Google Hotels search. Without keys, the wizard
# uses deterministic mock data — safe for demo / dev.
HOTEL_SEARCH_PROVIDER=           # serpapi | tavily | mock
SERPAPI_KEY=
TAVILY_API_KEY=

# ---- Hotel Details Fetcher -------------------------------------------------
HOTEL_DETAILS_PROVIDER=          # serpapi | mock

# ---- Google Maps / Places (real location fetch) ---------------------------
# Without this the wizard uses a deterministic India-cities mock that still
# auto-fills lat/lng/address — good enough for QA. Real Places API gives
# accurate results for any property.
GOOGLE_MAPS_API_KEY=

# ---- Video Verification AI Engine -----------------------------------------
# Mock mode runs by default — produces deterministic trust scores from
# metadata so the wizard demos all states. Set ANY of these to graduate
# to a real provider; the abstraction in lib/verify/ai.ts auto-picks.
AI_VERIFY_PROVIDER=               # google | aws | openai | mock
GOOGLE_VIDEO_API_KEY=
AWS_REKOG_KEY=
AWS_REKOG_SECRET=
OPENAI_API_KEY=

# ---- AI Dynamic Pricing — competitor scraper ------------------------------
# Default (no key) = mock provider that returns realistic competitor prices
# at floor_price × 1.4–1.85 across MakeMyTrip / Goibibo / Booking.com / OYO.
# Set ANY of these to graduate to a real scraper.
PRICING_SCRAPER_PROVIDER=         # scraperapi | apify | rapidapi | mock
SCRAPER_API_KEY=
APIFY_TOKEN=
RAPIDAPI_HOTELS_KEY=

# ---- Cron secret -----------------------------------------------------------
# Vercel Cron must hit /api/cron/pricing?token=$CRON_SECRET (or send
# x-cron-secret header). Defaults to "staybid-cron-dev" — CHANGE in prod.
CRON_SECRET=staybid-cron-dev

# ---- Bank account encryption (AES-256-GCM) --------------------------------
# 64-char hex string. Falls back to a key derived from ONBOARD_JWT_SECRET if
# unset. Production: ALWAYS set this explicitly and never reuse the JWT secret.
ONBOARD_ENC_KEY=

# ============================================================================
# How keys get picked up — no code changes needed:
#   1) Set the variable in Vercel
#   2) Redeploy
#   3) The provider abstraction auto-detects and switches
# ============================================================================
